        "### ၃။ `*args` နှင့် `**kwargs` ကို Flexible Argument များအတွက် အသုံးပြုခြင်း\n",
        "\n",
        "Function တစ်ခုသည် မည်မျှသော positional သို့မဟုတ် keyword argument များကို လက်ခံမည်ကို မသိနိုင်သည့်အခါများရှိသည်။ `*args` သည် function အား positional argument များကို အရေအတွက် အကန့်အသတ်မရှိ လက်ခံနိုင်စေပြီး `**kwargs` သည် keyword argument များကို အရေအတွက် အကန့်အသတ်မရှိ လက်ခံနိုင်စေသည်။"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "3e47a9db"
      },
      "source": [
        "def process_data(operation: str, *args: float, **kwargs: str) -> None:\n",
        "    \"\"\"\n",
        "    ပေးထားသော operation ကို ဂဏန်းများပေါ်တွင် လုပ်ဆောင်ပြီး ထပ်ဆောင်းရွေးချယ်မှုများကို ကိုင်တွယ်သည်။\n",
        "\n",
        "    Args:\n",
        "        operation (str): လုပ်ဆောင်ရမည့် operation (ဥပမာ: 'sum', 'product')။\n",
        "        *args (float): arbitrary positional argument များ (ဂဏန်းများ)။\n",
        "        **kwargs (str): arbitrary keyword argument များ (ဥပမာ: 'verbose', 'log_level')။\n",
        "\n",
        "    Returns:\n",
        "        None\n",
        "    \"\"\"\n",
        "    print(f\"လုပ်ဆောင်ချက်: {operation}\")\n",
        "    print(f\"ပေးထားသော ဂဏန်းများ: {args}\")\n",
        "    print(f\"ထပ်ဆောင်းရွေးချယ်မှုများ: {kwargs}\")\n",
        "\n",
        "    if operation == 'sum':\n",
        "        total = sum(args)\n",
        "        print(f\"ဂဏန်းများ၏ ပေါင်းလဒ်: {total}\")\n",
        "    elif operation == 'product':\n",
        "        product = 1\n",
        "        for num in args:\n",
        "            product *= num\n",
        "        print(f\"ဂဏန်းများ၏ မြှောက်လဒ်: {product}\")\n",
        "    else:\n",
        "        print(f\"မသိသော လုပ်ဆောင်ချက်: {operation}\")\n",
        "\n",
        "    if 'verbose' in kwargs and kwargs['verbose'].lower() == 'true':\n",
        "        print(\"Verbose output ကို ဖွင့်ထားသည်။\")\n",
        "\n",
        "# အသုံးပြုပုံ ဥပမာ:\n",
        "process_data('sum', 1, 2, 3, 4, verbose='true', log_level='info')\n",
        "print(\"---\\n\")\n",
        "process_data('product', 5, 2, 3)\n",
        "print(\"---\\n\")\n",
        "process_data('average', 10, 20, 30, unit='meters')\n"
      ],
      "execution_count": null,
      "outputs": []
    },
