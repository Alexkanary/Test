      },
      "source": [
        "def calculate_rectangle_area(length: float, width: float) -> float:\n",
        "    \"\"\"\n",
        "    စတုဂံ၏ ဧရိယာကို တွက်ချက်သည်။\n",
        "\n",
        "    Args:\n",
        "        length (float): စတုဂံ၏ အလျား။\n",
        "        width (float): စတုဂံ၏ အနံ။\n",
        "\n",
        "    Returns:\n",
        "        float: စတုဂံ၏ ဧရိယာ။\n",
        "    \"\"\"\n",
        "    # အလျားနှင့်အနံသည် အနှုတ်တန်ဖိုး မဖြစ်ရပါ။\n",
        "    if length < 0 or width < 0:\n",
        "        raise ValueError(\"အလျားနှင့်အနံသည် အနှုတ်တန်ဖိုး မဖြစ်ရပါ။\")\n",
        "    return length * width\n",
        "\n",
        "# အသုံးပြုပုံ ဥပမာ:\n",
        "area = calculate_rectangle_area(10.5, 5.2)\n",
        "print(f\"ဧရိယာ: {area}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
