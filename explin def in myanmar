        "def fetch_user_data(user_id: int) -> dict:\n",
        "    \"\"\"\n",
        "    (အစမ်း) database မှ user data ကို ရယူသည်။\n",
        "    \"\"\"\n",
        "    print(f\"user_id: {user_id} အတွက် data များကို ရယူနေသည်။\")\n",
        "    # database ခေါ်ဆိုမှုကို အတုယူသည်။\n",
        "    if user_id == 1:\n",
        "        return {\"id\": 1, \"name\": \"Alice\", \"email\": \"alice@example.com\"}\n",
        "    else:\n",
        "        return {}\n",
        "\n",
        "def format_user_info(user_data: dict) -> str:\n",
        "    \"\"\"\n",
        "    user data ကို ဖတ်ရလွယ်ကူသော string အဖြစ် ပြောင်းလဲသည်။\n",
        "    \"\"\"\n",
        "    if not user_data:\n",
        "        return \"User ကို ရှာမတွေ့ပါ။\"\n",
        "    return f\"အမည်: {user_data.get('name', 'N/A')}, အီးမေးလ်: {user_data.get('email', 'N/A')}\"\n",
        "\n",
        "# အသုံးပြုပုံ ဥပမာ:\n",
        "user_id = 1\n",
        "raw_data = fetch_user_data(user_id)\n",
        "formatted_output = format_user_info(raw_data)\n",
        "print(formatted_output)\n",
        "\n",
        "user_id = 2\n",
        "raw_data = fetch_user_data(user_id)\n",
        "formatted_output = format_user_info(raw_data)\n",
        "print(formatted_output)"
      ],
