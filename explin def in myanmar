        "### ၂။ Default Argument များနှင့် Error Handling\n",
        "\n",
        "ရွေးချယ်နိုင်သော parameter များအတွက် default တန်ဖိုးများကို ထောက်ပံ့ပေးခြင်းဖြင့် function များကို ပိုမိုပြောင်းလွယ်ပြင်လွယ် ဖြစ်စေသည်။ မှားယွင်းသော ထည့်သွင်းမှုများ သို့မဟုတ် မမျှော်လင့်ထားသော အခြေအနေများမှ ကာကွယ်ရန် error handling (ဥပမာ: `try-except` blocks သို့မဟုတ် သင့်လျော်သော exceptions များကို `raise` လုပ်ခြင်း) ကို အကောင်အထည်ဖော်ပါ။"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "c5750733"
      },
      "source": [
        "def divide_numbers(numerator: float, denominator: float = 1.0) -> float:\n",
        "    \"\"\"\n",
        "    ဂဏန်းနှစ်ခုကို စားသည်။ denominator ကို default တန်ဖိုးပေးထားသည်။\n",
        "\n",
        "    Args:\n",
        "        numerator (float): အစားခံရမည့် ဂဏန်း။\n",
        "        denominator (float, optional): အစားခံရမည့် ဂဏန်း။ default မှာ 1.0 ဖြစ်သည်။\n",
        "\n",
        "    Returns:\n",
        "        float: စားခြင်း၏ ရလဒ်။\n",
        "\n",
        "    Raises:\n",
        "        ValueError: denominator သုည ဖြစ်ပါက။\n",
        "    \"\"\"\n",
        "    # သုညဖြင့် စား၍မရပါ။\n",
        "    if denominator == 0:\n",
        "        raise ValueError(\"သုညဖြင့် စား၍မရပါ။\")\n",
        "    return numerator / denominator\n",
        "\n",
        "# default denominator ဖြင့် အသုံးပြုပုံ ဥပမာ:\n",
        "result1 = divide_numbers(10)\n",
        "print(f\"10 ကို 1 (default) ဖြင့် စားခြင်း: {result1}\")\n",
        "\n",
        "# သတ်မှတ်ထားသော denominator ဖြင့် အသုံးပြုပုံ ဥပမာ:\n",
        "result2 = divide_numbers(10, 2.5)\n",
        "print(f\"10 ကို 2.5 ဖြင့် စားခြင်း: {result2}\")\n",
        "\n",
        "# error handling ဖြင့် အသုံးပြုပုံ ဥပမာ:\n",
        "try:\n",
        "    divide_numbers(10, 0)\n",
        "except ValueError as e:\n",
        "    print(f\"Error: {e}\")"
      ],
      "execution_count": null,
      "outputs": []
    },
